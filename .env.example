DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# ─── Cookie security ───────────────────────────────────────────────────────────
# When DJANGO_DEBUG=1 (HTTP-only local dev) these default to 0 automatically.
# For a production HTTPS deployment set both to 1, otherwise the browser silently
# discards session cookies and every request appears unauthenticated (401 errors).
# DJANGO_SESSION_COOKIE_SECURE=1
# DJANGO_CSRF_COOKIE_SECURE=1
# DJANGO_USE_X_FORWARDED_PROTO=1
# DJANGO_USE_X_FORWARDED_HOST=1
# DJANGO_SESSION_COOKIE_SAMESITE=Lax
# DJANGO_CSRF_COOKIE_SAMESITE=Lax
# For deployments that serve both apex and www hosts, share cookies across both:
# DJANGO_SESSION_COOKIE_DOMAIN=.cogflow.app
# DJANGO_CSRF_COOKIE_DOMAIN=.cogflow.app
# Also trust both origins for CSRF checks:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://cogflow.app,https://www.cogflow.app
# For split-host production (public site + portal subdomain), include portal origin:
# DJANGO_ALLOWED_HOSTS=cogflow.app,www.cogflow.app,portal.cogflow.app
# DJANGO_CSRF_TRUSTED_ORIGINS=https://cogflow.app,https://www.cogflow.app,https://portal.cogflow.app
# ───────────────────────────────────────────────────────────────────────────────

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=cogflow_platform
POSTGRES_USER=cogflow
POSTGRES_PASSWORD=cogflow

IDENTIFIER_SALT=replace-me
RESULT_ENCRYPTION_KEY=replace-with-fernet-key

# Day 6 MFA settings (user-based auth + TOTP)
# Issuer label shown in authenticator apps when scanning TOTP setup URI.
MFA_TOTP_ISSUER=CogFlow Platform

# Max age (seconds) for a verified MFA session before sensitive actions
# (e.g., /api/v1/results/decrypt) require re-verification.
MFA_REAUTH_SECONDS=900

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─────────────────────────────────────────────────────────────────
# Platform feature flags — injected into frontend HTML by Django
# views (or set manually in index.html during local development).
# ─────────────────────────────────────────────────────────────────

# Base URL the browser uses to reach this Django instance.
# Setting this in frontend/builder/index.html (window.COGFLOW_PLATFORM_URL)
# enables the "Platform Publish" button in the Builder.
# Setting it in frontend/interpreter/index.html enables the
# DjangoRuntimeBackend result-submission path.
# Leave empty to keep using JATOS / local-download mode.
COGFLOW_PLATFORM_URL=http://localhost:8000
# Production example for host-split rollout:
# COGFLOW_PLATFORM_URL=https://portal.cogflow.app

# Default study slug for the Builder publish flow.
# COGFLOW_STUDY_SLUG=my-study

# Default config version label for the Builder publish flow.
# COGFLOW_CONFIG_VERSION=v1

# ─── Scheduled maintenance mode (portal-wide lockout) ─────────────────────────
# Set to 1 to block portal access and return a maintenance notice for all
# non-exempt routes. Set back to 0 when maintenance is complete.
COGFLOW_MAINTENANCE_MODE=0

# Default retry notice shown to users (hours).
COGFLOW_MAINTENANCE_RETRY_HOURS=5

# Human-readable window label shown in notice/API responses.
COGFLOW_MAINTENANCE_WINDOW=Friday 7:00 PM to 12:00 AM (Sydney time)

# Optional custom message override.
# COGFLOW_MAINTENANCE_MESSAGE=CogFlow Platform is temporarily unavailable for scheduled maintenance. Please check back in about 5 hours.

# Keep Django admin reachable during maintenance (1=yes, 0=no).
COGFLOW_MAINTENANCE_ALLOW_ADMIN=1

# Support contact shown on maintenance page.
COGFLOW_SUPPORT_EMAIL=support@cogflow.app

